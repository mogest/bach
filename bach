PATHS
  ~/.local/share/bach/projects/<proj>/   Per-project Claude history.
  ~/.local/share/bach/cache/mise/        Shared mise tool cache.
  ~/.local/state/bach/proxy.log          bach-proxy log (apple backend).
                                         (docker backend: `bach log` tails
                                         `docker logs bach-proxy`.)
"""


def usage(exit_code: int = 2) -> None:
    out = sys.stdout if exit_code == 0 else sys.stderr
    print(HELP_TEXT, file=out, end="")
    sys.exit(exit_code)

def main() -> None:
    raw = sys.argv[1:]
    args: list[str] = []
    for a in raw:
        if a in ("-h", "--help"):
            usage(0)
        else:
            args.append(a)

    root, cfg = find_project()
    backend = select_backend(cfg)

    # Reap port allocations belonging to sessions that are no longer running.
    # Safety net for the SIGKILL-bach case where the per-session cleanup
    # handler didn't get to fire. Best-effort: a broken backend just means
    # the file stays as-is until the next successful invocation.
    try:
        reap_ports(set(backend.list_all_running_sessions()))
    except Exception as e:
        print(f"bach: warning: port reap failed: {e}", file=sys.stderr)

    if args and args[0] == "up":
        net = project_id(root)
        backend.ensure_network(net)
        backend.ensure_proxy(net)
        allocs = _load_ports_state().get("allocations", [])
        register_project_with_proxy(
            root, cfg, backend, net,
            ports=project_port_map(allocs, root.name),
        )
        forwards = build_forwards(allocs, root.name, lambda s: backend.container_ip(s, net))
        post_forwards_to_proxy(root.name, forwards)
        ensure_services(root, cfg, net, backend)
        print("bach: up")
    elif args and args[0] == "down":
        stop_services(root, cfg, backend)
        print("bach: down")
    elif args and args[0] == "status":
        cmd_status(backend)
    elif args and args[0] == "log":
        cmd_log(backend)
    elif args and args[0] == "ps":
        cmd_ps(backend)
    elif args and args[0] == "build":
        cmd_build(backend)
    elif args and args[0] in ("exec", "e"):
        cmd_exec(backend, args[1:])
    elif args and args[0] in ("shell", "s"):
        session(root, cfg, ["bash", "-l"], backend, guard=True)
    elif args and args[0] in ("claude", "c"):
        if len(args) == 1:
            # Interactive bash that auto-runs claude. Gives proper job control
            # (Ctrl-Z suspends claude, drops to shell; fg resumes).
            session(root, cfg, ["bash", "--rcfile", "/etc/bach-rcfile", "-i"], backend, guard=True)
        else:
            session(root, cfg, ["claude", *args[1:]], backend)
    elif args and args[0] == "run":
        if len(args) < 2:
            usage()
        session(root, cfg, args[1:], backend)
    elif args and args[0] == "help":
        usage(0)
    elif args:
        print(f"bach: unknown subcommand {args[0]!r}", file=sys.stderr)
        usage(2)
    else:
        # Default: shell.
        session(root, cfg, ["bash", "-l"], backend, guard=True)

if __name__ == "__main__":
    main()
